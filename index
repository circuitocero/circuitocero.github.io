<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#0a0a0a">
<title>CIRCUITO CERO® — Plataforma Educativa</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=IBM+Plex+Mono:wght@400;500;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
<style>
:root{
  --red:#e63946;--red2:#c1121f;--navy:#1d3557;--navy2:#457b9d;--teal:#a8dadc;
  --bg:#0a0a0a;--bg2:#111111;--bg3:#1a1a1a;--surface:#1e1e1e;--surface2:#252525;
  --white:#ffffff;--text:#f0f0f0;--muted:#888;--muted2:#555;
  --border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.12);
  --font:'Outfit',sans-serif;--disp:'Syne',sans-serif;--mono:'IBM Plex Mono',monospace;
  --ease:cubic-bezier(.16,1,.3,1);--ease2:cubic-bezier(.19,1,.22,1);
  --r:16px;--max:480px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;background:var(--bg);overscroll-behavior-y:contain;}
body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;max-width:var(--max);margin:0 auto;overflow-x:hidden;position:relative;}
img{max-width:100%;height:auto;display:block;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-thumb{background:var(--red);border-radius:2px;}

/* ── TOPBAR (stories-style) ── */
.topbar{
  position:sticky;top:0;z-index:100;
  background:rgba(10,10,10,.95);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  padding:10px 16px;
  display:flex;align-items:center;gap:10px;
}
.topbar-logo{width:34px;height:34px;border-radius:50%;border:2px solid var(--red);padding:2px;flex-shrink:0;object-fit:contain;background:#fff;}
.topbar-name{font-family:var(--disp);font-size:1rem;font-weight:800;color:var(--white);letter-spacing:-.02em;}
.topbar-name span{color:var(--red);}
.topbar-sub{font-family:var(--mono);font-size:.58rem;color:var(--muted);display:block;margin-top:1px;}
.topbar-right{margin-left:auto;display:flex;gap:8px;align-items:center;}
.tb-btn{
  background:var(--red);color:#fff;border:none;
  font-family:var(--mono);font-size:.65rem;font-weight:700;
  padding:6px 14px;border-radius:999px;cursor:pointer;
  display:flex;align-items:center;gap:4px;
  transition:background .2s,transform .15s;
  text-decoration:none;
}
.tb-btn:hover{background:var(--red2);transform:scale(.97);}
.material-symbols-outlined{font-size:1em!important;vertical-align:middle;}

/* ── HERO COVER (like a pinned post) ── */
.hero-cover{
  position:relative;width:100%;
  aspect-ratio:16/9;
  overflow:hidden;
  background:#0a0a0a;
}
.hero-cover img{
  width:100%;height:100%;object-fit:cover;
  display:block;
}
.hero-cover-overlay{
  position:absolute;inset:0;
  background:linear-gradient(0deg, rgba(0,0,0,.85) 0%, rgba(0,0,0,.3) 50%, transparent 100%);
}
.hero-cover-text{
  position:absolute;bottom:0;left:0;right:0;
  padding:20px 16px 16px;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--red);color:#fff;
  font-family:var(--mono);font-size:.6rem;font-weight:700;
  padding:3px 10px;border-radius:999px;letter-spacing:1px;
  text-transform:uppercase;margin-bottom:8px;
}
.hero-title{
  font-family:var(--disp);font-size:1.7rem;font-weight:800;
  color:#fff;line-height:1;letter-spacing:-.04em;margin-bottom:4px;
}
.hero-title span{color:var(--red);}
.hero-sub{font-family:var(--font);font-size:.8rem;color:rgba(255,255,255,.7);line-height:1.5;}

/* ── STATS ROW (like story highlights) ── */
.stats-row{
  display:flex;gap:0;
  border-bottom:1px solid var(--border);
  background:var(--bg2);
}
.stat-item{
  flex:1;text-align:center;padding:14px 8px;
  position:relative;
  cursor:default;
}
.stat-item+.stat-item::before{content:'';position:absolute;left:0;top:20%;bottom:20%;width:1px;background:var(--border);}
.stat-n{font-family:var(--disp);font-size:1.3rem;font-weight:800;color:var(--white);line-height:1;}
.stat-n.r{color:var(--red);}
.stat-n.t{color:var(--teal);}
.stat-l{font-family:var(--mono);font-size:.52rem;color:var(--muted);margin-top:2px;text-transform:uppercase;letter-spacing:.08em;}

/* ── SECTION HEADERS ── */
.sec-header{
  padding:20px 16px 12px;
  display:flex;align-items:center;justify-content:space-between;
}
.sec-title{font-family:var(--disp);font-size:1.05rem;font-weight:800;color:var(--white);letter-spacing:-.02em;}
.sec-title span{color:var(--red);}
.sec-more{font-family:var(--mono);font-size:.65rem;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:3px;transition:color .2s;}
.sec-more:hover{color:var(--red);}

/* ── DIVIDER ── */
.divider{height:8px;background:var(--bg3);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}

/* ── CATEGORY CHIPS (horizontal scroll) ── */
.chips-wrap{
  padding:0 16px 14px;overflow-x:auto;
  display:flex;gap:7px;
  scrollbar-width:none;
}
.chips-wrap::-webkit-scrollbar{display:none;}
.chip{
  flex-shrink:0;
  background:var(--surface);border:1px solid var(--border2);
  color:var(--muted);
  font-family:var(--mono);font-size:.65rem;font-weight:600;
  padding:6px 14px;border-radius:999px;cursor:pointer;
  transition:all .18s var(--ease);white-space:nowrap;
}
.chip.active,.chip:hover{background:var(--red);color:#fff;border-color:var(--red);}

/* ── VIDEO CARDS (TikTok/Reels style feed) ── */
.videos-feed{padding:0 12px 12px;display:flex;flex-direction:column;gap:10px;}
.vcard{
  background:var(--surface);border-radius:14px;overflow:hidden;
  border:1px solid var(--border);
  transition:transform .2s var(--ease);
  position:relative;
}
.vcard:active{transform:scale(.98);}

/* Thumbnail — tall shorts ratio */
.vcard-thumb{
  position:relative;padding-bottom:75%;background:#0a0a0a;overflow:hidden;
}
.vcard-thumb iframe{position:absolute;inset:0;width:100%;height:100%;border:none;}
.vcard-num{
  position:absolute;top:8px;left:8px;z-index:2;
  background:rgba(0,0,0,.7);backdrop-filter:blur(8px);
  color:#fff;font-family:var(--mono);font-size:.6rem;font-weight:700;
  padding:3px 8px;border-radius:6px;
}
.shorts-pill{
  position:absolute;top:8px;right:8px;z-index:2;
  background:var(--red);color:#fff;
  font-family:var(--mono);font-size:.55rem;font-weight:700;
  padding:2px 7px;border-radius:999px;letter-spacing:.5px;
}

.vcard-body{padding:10px 12px 12px;}
.vcard-title{font-family:var(--disp);font-size:.92rem;font-weight:700;color:var(--white);line-height:1.3;margin-bottom:6px;}
.vcard-meta{display:flex;align-items:center;justify-content:space-between;}
.vcard-chan{font-family:var(--mono);font-size:.6rem;color:var(--muted);display:flex;align-items:center;gap:4px;}
.vcard-cat-badge{
  font-family:var(--mono);font-size:.58rem;font-weight:700;
  padding:3px 9px;border-radius:999px;
  background:rgba(230,57,70,.15);color:var(--red);
  border:1px solid rgba(230,57,70,.2);
}
.vcard-actions{
  display:flex;align-items:center;gap:8px;margin-top:10px;padding-top:10px;
  border-top:1px solid var(--border);
}
.vcard-yt{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(255,0,0,.12);color:#ff4444;border:1px solid rgba(255,0,0,.2);
  font-family:var(--mono);font-size:.6rem;font-weight:700;
  padding:5px 12px;border-radius:999px;text-decoration:none;
  transition:background .18s;flex:1;justify-content:center;
}
.vcard-yt:hover{background:rgba(255,0,0,.22);}
.like-btn{
  width:34px;height:34px;border-radius:50%;background:var(--surface2);border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  color:var(--muted);transition:all .18s;flex-shrink:0;
}
.like-btn.liked{background:rgba(230,57,70,.15);border-color:rgba(230,57,70,.3);color:var(--red);}

/* ── COUNT BAR ── */
.count-bar{
  margin:0 16px 12px;
  background:var(--surface);border-radius:10px;
  padding:10px 14px;
  display:flex;align-items:center;gap:8px;
  border:1px solid var(--border);
}
.count-pill{background:var(--navy);color:#fff;padding:3px 10px;border-radius:999px;font-family:var(--mono);font-size:.62rem;font-weight:700;}
.count-label{font-family:var(--mono);font-size:.65rem;color:var(--muted);}

/* ── WIKI SECTION ── */
.wiki-section{
  background:var(--bg2);
  padding:0 0 16px;
}
.wiki-inner{padding:0 16px;}
.wiki-input-row{display:flex;gap:8px;margin-bottom:0;}
.wiki-input{
  flex:1;background:var(--surface);border:1px solid var(--border2);
  color:var(--text);font-family:var(--font);font-size:.85rem;
  padding:11px 14px;border-radius:10px;outline:none;
  transition:border .2s;
}
.wiki-input:focus{border-color:var(--red);}
.wiki-input::placeholder{color:var(--muted2);}
.wiki-btn{
  background:var(--red);color:#fff;border:none;
  font-family:var(--disp);font-size:.78rem;font-weight:700;
  padding:11px 16px;border-radius:10px;cursor:pointer;
  transition:background .2s;white-space:nowrap;
}
.wiki-btn:hover{background:var(--red2);}
.wiki-result{
  margin-top:12px;background:var(--surface);border-radius:12px;
  padding:14px;border:1px solid var(--border);
  font-size:.82rem;line-height:1.7;color:var(--text);
  display:none;
}
.wiki-result.show{display:block;}
.wiki-result h4{font-family:var(--disp);font-size:1rem;font-weight:800;color:var(--red);margin-bottom:8px;}
.wiki-result a{color:var(--teal);font-size:.78rem;}

/* ── TIMELINE ── */
.timeline-sec{padding:0 16px 20px;}
.tl-item{display:flex;gap:14px;margin-bottom:20px;position:relative;}
.tl-left{display:flex;flex-direction:column;align-items:center;width:36px;flex-shrink:0;}
.tl-dot-outer{width:14px;height:14px;border-radius:50%;background:var(--red);border:3px solid var(--bg);box-shadow:0 0 0 2px var(--red);flex-shrink:0;margin-top:3px;}
.tl-line-v{flex:1;width:2px;background:linear-gradient(var(--red),var(--navy));margin-top:6px;min-height:30px;}
.tl-item:last-child .tl-line-v{display:none;}
.tl-yr{font-family:var(--mono);font-size:.58rem;color:var(--red);font-weight:700;letter-spacing:1.5px;margin-bottom:3px;}
.tl-name{font-family:var(--disp);font-size:1rem;font-weight:800;color:var(--white);margin-bottom:4px;}
.tl-desc{font-size:.78rem;color:var(--muted);line-height:1.6;}

/* ── TEAM SECTION ── */
.team-section{padding:0 16px 20px;}
.director-card{
  background:linear-gradient(135deg,#0d1f36,#1a2e48);
  border-radius:14px;padding:16px;
  display:flex;align-items:center;gap:12px;
  border:1px solid rgba(69,123,157,.25);
  margin-bottom:10px;
}
.dir-av{
  width:54px;height:54px;border-radius:12px;flex-shrink:0;
  background:linear-gradient(135deg,var(--red),#ff6b6b);
  display:flex;align-items:center;justify-content:center;
  font-weight:800;color:#fff;font-size:1.1rem;
  box-shadow:0 4px 14px rgba(230,57,70,.3);
}
.dir-name{font-family:var(--disp);font-size:1rem;font-weight:800;color:#fff;margin-bottom:2px;}
.dir-role{font-family:var(--mono);font-size:.6rem;color:var(--teal);letter-spacing:.5px;}
.dir-badge{
  margin-left:auto;background:rgba(168,218,220,.12);border:1px solid rgba(168,218,220,.2);
  color:var(--teal);padding:4px 10px;border-radius:999px;
  font-family:var(--mono);font-size:.58rem;font-weight:700;letter-spacing:.5px;white-space:nowrap;
}
.team-grid{display:flex;flex-direction:column;gap:7px;}
.team-card{
  background:var(--surface);border-radius:12px;padding:12px 14px;
  display:flex;align-items:center;gap:12px;
  border:1px solid var(--border);border-left:3px solid var(--navy2);
  transition:transform .18s,border-color .18s;
}
.team-card:active{transform:scale(.98);}
.team-av{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.85rem;flex-shrink:0;}
.team-name{font-family:var(--disp);font-size:.88rem;font-weight:800;color:var(--white);}
.team-role{font-family:var(--mono);font-size:.58rem;color:var(--muted);margin-top:1px;}

/* ── BYG CARD ── */
.byg-section{padding:16px;}
.byg-card{
  background:linear-gradient(135deg,var(--red) 0%,var(--red2) 100%);
  border-radius:20px;padding:24px 20px;text-align:center;
  position:relative;overflow:hidden;
}
.byg-card::before{
  content:'';position:absolute;top:-30%;right:-20%;
  width:200px;height:200px;border-radius:50%;
  background:rgba(255,255,255,.06);
}
.byg-card::after{
  content:'';position:absolute;bottom:-20%;left:-10%;
  width:150px;height:150px;border-radius:50%;
  background:rgba(0,0,0,.08);
}
.byg-logo{width:56px;height:56px;border-radius:14px;margin:0 auto 12px;border:3px solid rgba(255,255,255,.3);object-fit:contain;background:#fff;padding:4px;}
.byg-title{font-family:var(--disp);font-size:1.3rem;font-weight:800;color:#fff;margin-bottom:6px;line-height:1.1;}
.byg-sub{font-size:.8rem;color:rgba(255,255,255,.75);margin-bottom:18px;line-height:1.5;}
.byg-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;position:relative;z-index:1;}
.byg-btn-w{
  background:#fff;color:var(--red);
  font-family:var(--disp);font-size:.82rem;font-weight:800;
  padding:10px 20px;border-radius:999px;text-decoration:none;
  display:flex;align-items:center;gap:5px;
  transition:transform .15s;
}
.byg-btn-w:hover{transform:scale(.97);}
.byg-btn-t{
  background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.25);
  font-family:var(--mono);font-size:.78rem;font-weight:700;
  padding:10px 16px;border-radius:999px;text-decoration:none;
  display:flex;align-items:center;gap:5px;
  transition:background .18s;
}
.byg-btn-t:hover{background:rgba(255,255,255,.22);}

/* ── FOOTER ── */
.footer-bar{
  background:var(--bg2);border-top:1px solid var(--border);
  padding:20px 16px;text-align:center;
}
.footer-logo-row{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:6px;}
.footer-logo-img{width:28px;height:28px;border-radius:50%;border:1.5px solid var(--red);padding:2px;background:#fff;object-fit:contain;}
.footer-brand{font-family:var(--disp);font-size:.95rem;font-weight:800;color:var(--white);letter-spacing:-.02em;}
.footer-brand span{color:var(--red);}
.footer-copy{font-family:var(--mono);font-size:.55rem;color:var(--muted);margin-top:4px;}

/* ── BOTTOM NAV (mobile social style) ── */
.bottom-nav{
  position:fixed;bottom:0;left:50%;transform:translateX(-50%);
  width:100%;max-width:var(--max);
  background:rgba(10,10,10,.97);backdrop-filter:blur(20px);
  border-top:1px solid var(--border);
  display:flex;z-index:200;
  padding-bottom:env(safe-area-inset-bottom);
}
.bnav-item{
  flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;
  padding:10px 4px 8px;cursor:pointer;
  text-decoration:none;
  transition:opacity .15s;
  color:var(--muted);
}
.bnav-item.active,.bnav-item:hover{color:var(--white);}
.bnav-item.active .bnav-icon{color:var(--red);}
.bnav-icon{font-size:1.4em!important;}
.bnav-label{font-family:var(--mono);font-size:.52rem;letter-spacing:.3px;}

/* space for bottom nav */
.bottom-space{height:72px;}

/* ── SCROLL PROGRESS ── */
#prog{position:fixed;top:0;left:0;height:2px;background:var(--red);z-index:999;width:0%;transition:width .08s linear;}

/* ── REVEAL ANIM ── */
.rev{opacity:0;transform:translateY(24px);transition:opacity .6s var(--ease),transform .6s var(--ease);}
.rev.in{opacity:1;transform:none;}
</style>
</head>
<body>

<div id="prog"></div>

<!-- TOP BAR -->
<header class="topbar">
  <img class="topbar-logo" src="data:image/png;base64," alt="Logo Circuito Cero">
  <div>
    <div class="topbar-name">CIRCUITO <span>CERO</span><sup style="font-size:.5em;color:#666">®</sup></div>
    <span class="topbar-sub">Plataforma Educativa · México</span>
  </div>
  <div class="topbar-right">
    <a href="https://www.youtube.com/@circuitocero" target="_blank" class="tb-btn">
      <span class="material-symbols-outlined">smart_display</span>
      YouTube
    </a>
  </div>
</header>

<!-- HERO COVER -->
<div class="hero-cover">
  <img src="data:image/png;base64,/9j/4AAQSkZJRgABAQAAAQABAAD/4gHYSUNDX1BST0ZJTEUAAQEAAA
